{
  "name": "@repo/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:check-baseline": "tsx src/checkBaseline.ts",
    "db:baseline-existing": "npm run db:check-baseline && prisma migrate resolve --applied 20260714000000_baseline",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "5.9.2"
  }
}
