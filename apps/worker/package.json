  "dependencies": {
    "@repo/database": "*",
    "node-cron": "^3.0.3",
    "dotenv": "^16.5.0",
    "undici": "^7.5.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "5.9.2"
