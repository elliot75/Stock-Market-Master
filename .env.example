# ============================================
# 台股分析大師系統 - 環境變數範本
# 複製此檔為 .env 並填入真實值
# ============================================

# --- 資料庫 ---
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- 應用程式 ---
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# --- 外部資料來源 ---
TWSE_BASE_URL=https://openapi.twse.com.tw
TPEX_BASE_URL=https://www.tpex.org.tw
FINMIND_BASE_URL=https://api.finmindtrade.com/api/v4/data
FINMIND_TOKEN=your_finmind_token_here

# --- 排程設定 ---
WORKER_TIMEZONE=Asia/Taipei

# --- 安全性 ---
# 使用以下指令產生：openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
# 輪替時暫時保留舊金鑰，完成轉換後移除
# APP_ENCRYPTION_KEY_PREVIOUS=

# --- AI 個股分析 ---
# 自訂 OpenAI-compatible 端點；可用 http://，省略 scheme 時會視為 http://
LLM_DEFAULT_PROVIDER=custom
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=60000

# 只會顯示已同時設定 API Key 與 Model 的官方供應商
OPENAI_API_KEY=
OPENAI_MODEL=
# OPENAI_BASE_URL=https://api.openai.com/v1
XAI_API_KEY=
XAI_MODEL=
# XAI_BASE_URL=https://api.x.ai/v1
GEMINI_API_KEY=
GEMINI_MODEL=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Web 部署在 Caddy 後方時保留空白，前端會使用同源 /api
NEXT_PUBLIC_API_URL=

# --- 未來擴充 (盤中行情商 / 通知服務) ---
# MARKET_DATA_VENDOR_API_KEY=
# NOTIFICATION_SERVICE_URL=
# NOTIFICATION_SERVICE_API_KEY=
